{
	admin off
	auto_https off
	persist_config off
}

:8080 {
	root * /srv
	encode zstd gzip

	handle /healthz {
		respond "ok" 200
	}

	handle {
		@nuxtAssets path /_nuxt/*
		header @nuxtAssets Cache-Control "public, max-age=31536000, immutable"

		@html path / *.html
		header @html Cache-Control "public, max-age=0, must-revalidate"

		try_files {path} {path}/ /index.html
		file_server
	}
}
